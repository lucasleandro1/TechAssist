<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Registros</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 50px;
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 10px;
        }

        .form-container h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }

        .form-group input[type="file"] {
            padding: 3px;
        }

        .form-group input[type="submit"] {
            background-color: #4CAF50;
            color: white;
            border: none;
            cursor: pointer;
            padding: 10px;
            font-size: 16px;
        }

        .form-group input[type="submit"]:hover {
            background-color: #45a049;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h2>Cadastro de Registros</h2>
        <%= form_with model: @registro, local: true, html: { enctype: "multipart/form-data" } do |f| %>
            <div class="form-group">
                <%= f.label :data_abertura, "Data de Abertura:" %>
                <%= f.date_field :data_abertura, required: true, id: "data_abertura" %>
            </div>
            <div class="form-group">
                <%= f.label :data_fechamento, "Data de Fechamento:" %>
                <%= f.date_field :data_fechamento, id: "data_fechamento" %>
            </div>
            <div class="form-group">
                <%= f.label :descricao, "Descrição:" %>
                <%= f.text_area :descricao, rows: 4, required: true, id: "descricao" %>
            </div>
            <div class="form-group">
                <%= f.label :status, "Status:" %>
                <%= f.select :status, [["Aberto", "aberto"], ["Em Progresso", "em_progresso"], ["Fechado", "fechado"]], required: true, id: "status" %>
            </div>
            <div class="form-group">
                <%= f.label :comentario, "Comentário:" %>
                <%= f.text_area :comentario, rows: 4, id: "comentario" %>
            </div>
            <div class="form-group">
                <%= f.label :sintoma, "Sintoma:" %>
                <%= f.text_field :sintoma, required: true, id: "sintoma" %>
            </div>
            <div class="form-group">
                <%= f.label :anexo, "Anexo:" %>
                <%= f.file_field :anexo, id: "anexo" %>
            </div>
            <div class="form-group">
                <%= f.submit "Cadastrar Registro", class: "btn btn-primary btn-block" %>
            </div>
        <% end %>
    </div>

</body>
</html>
